@{
    ViewData["Title"] = "Chat";
}

<div class="uk-card-header border-bottom">
    <div class="uk-grid-small uk-flex-middle" uk-grid>
        <div class="uk-width-auto">
            <img class="uk-border-circle" width="100" height="100" src="~/image/Normam.png" alt="Normam">
        </div>
        <div class="uk-width-expand">
            <h3 class="uk-card-title uk-margin-remove-bottom">Normam</h3>
            <p class="uk-text-meta uk-margin-remove-top"><time datetime="2016-04-01T19:00">Chat</time></p>
        </div>
    </div>
</div>

<div class="uk-margin-medium-top chat" id="divChat">
    <ul class="uk-list" id="chatList">
        <li style="float: left; width: 90%;">
            <div class="balao-fala resposta">Olá sou o Chat Normam, em que posso ajudar ?</div>
        </li>
    </ul>
</div>

<div id="loading" class="balao-fala resposta loading" style="display: none;"><span>.</span><span>.</span><span>.</span></div>

<hr class="uk-divider-icon">

<form class="uk-margin-small" id="formChat" onsubmit="site.get(); return false;">
    <input id="inputChat" name="inputChat" class="uk-input" type="text" placeholder="Qual sua duvida?" style="width: 80%;">
    <button type="submit" id="btnChat" class="uk-button uk-button-default">ENVIAR</button>
</form>

<script>
    site.init({
        url: {
            chat: '@Url.Action("GetChat", "Normam")'
        }
    });
</script>